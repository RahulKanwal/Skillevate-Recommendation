# YouTube Data API v3 Key
# Get your key from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable YouTube Data API v3
# 3. Create credentials (API Key)
# 4. Copy the key below (do not commit real keys to the repository)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─────────────────────────────────────────────
# MongoDB Configuration
# ─────────────────────────────────────────────

# MongoDB connection string.
# For local development use the default below.
# For production, use your Atlas URI:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Name of the MongoDB database used by the application
MONGODB_DATABASE=skillevate_user

# ─────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Add any additional frontend origins as needed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────

# Human-readable name for the application (used in logs, health checks, etc.)
APP_NAME=Skillevate Recommendation API

# Application environment: development | staging | production
APP_ENV=development
